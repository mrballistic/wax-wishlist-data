{
  "name": "wax-wishlist-data",
  "version": "0.1.0",
  "private": true,
  "description": "Data pipeline and static JSON/art assets for the consuming iOS app",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "ingest": "tsx scripts/ingest.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "format": "prettier --write .",
    "validate": "tsx scripts/validate.ts"
  },
  "dependencies": {
    "pdf-parse": "1.1.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pdf-parse": "1.1.4",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-import": "2.31.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
